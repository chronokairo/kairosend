# ─────────────────────────────────────────────────────────────
# Kairosend — Resend desktop client (Next.js + Electron)
# Open-source. Covers Node, Next.js, TypeScript, Electron and
# electron-builder artifacts for Windows & Linux targets.
# ─────────────────────────────────────────────────────────────

# ── Dependencies ──────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/install-state.gz
.yarn/build-state.yml
jspm_packages/

# ── Next.js ───────────────────────────────────────────────────
.next/
out/
build/
dist/
.next-server/
next-env.d.ts

# ── TypeScript ────────────────────────────────────────────────
*.tsbuildinfo
.nyc_output/

# ── Production / Electron builds ──────────────────────────────
release/
release-builds/
releases/
app-builds/
packaged/
electron-builder.out/
