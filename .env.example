# ── Kairosend environment ──────────────────────────────────────
# Kairosend is local-first: each user enters their OWN Resend API key in the
# in-app Settings (stored in localStorage). No shared server secret is needed.
#
# This file is OPTIONAL. It only ships a fallback server-side key for hosted
# deployments / CI. For the desktop app, leave it blank and use Settings.

# Your Resend API key (https://resend.com/api-keys)
RESEND_API_KEY=

# Optional default "from" address used by the composer
RESEND_FROM_ADDRESS=

# Local port the Next.js server runs on (must match electron/main.js)
KAIROSEND_PORT=3000
